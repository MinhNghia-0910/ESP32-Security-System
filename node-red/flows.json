    {
        "id": "cb9d5247017be62f",
        "type": "function",
        "z": "ec778bc74331d5e1",
        "name": "Đếm lượt đi qua",
        "func": "let s = (msg.payload + \"\").trim();\nlet pir = (s === \"1\") ? 1 : 0;\n\nlet last = context.get('lastPir');\nif (last === undefined) last = 0;\n\nlet count = context.get('count');\nif (count === undefined) count = 0;\n\nif (last === 0 && pir === 1) {\n    count += 1;\n}\n\ncontext.set('lastPir', pir);\ncontext.set('count', count);\n\n\nreturn [\n    { payload: count },\n    { topic: \"Count\", payload: count }\n];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 440,
        "y": 200,
