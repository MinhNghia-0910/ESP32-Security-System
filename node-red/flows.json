    {
        "id": "73273438ca6c33f1",
        "type": "function",
        "z": "ec778bc74331d5e1",
        "name": "Gửi Email cảnh báo",
        "func": "let event = (msg.payload + \"\").trim().toUpperCase();\nif (event !== \"MOTION\") return null;\n\n// chống spam\nlet lastSent = flow.get(\"lastSent\") || 0;\nlet now = Date.now();\nif (now - lastSent < 60 * 1000) {\n    return null;\n}\nflow.set(\"lastSent\", now);\n\nmsg.topic = \"CẢNH BÁO AN NINH\";\nmsg.payload = \"Cảnh báo: phát hiện chuyển động tại khu vực giám sát vào lúc: \" + new Date().toLocaleString();\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 460,
        "y": 460,
